# Route @juiceco-io scope to GitHub Packages (private org registry).
# CI: NODE_AUTH_TOKEN is set by the workflow from secrets.GITHUB_TOKEN.
# Local dev: export NODE_AUTH_TOKEN=<GitHub PAT with read:packages scope>
@juiceco-io:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
